# Absolute origin of the FastAPI backend - used only by vite.config.ts's
# dev-server proxy (Node-side; never shipped to the browser bundle).
VITE_API_PROXY_TARGET=http://localhost:8000

# Relative base path the browser's axios client calls (wired in a later
# step). Works unchanged in dev (proxied above) and in a same-origin
# production deployment - only change this to an absolute URL if the
# built frontend is ever served from a different origin than the backend.
VITE_API_BASE_URL=/api