# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=guarded_agent_db

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# MCP Server Configuration
# Path to your MCP server executable/script
MCP_SERVER_COMMAND=python
MCP_SERVER_ARGS=path/to/your/mcp_server.py

# Agent Configuration
AGENT_NAME=GuardedAIAgent
POLICY_CHECK_INTERVAL=2

# Logging
LOG_LEVEL=INFO

# Optional: External Approver Configuration
# APPROVER_WEBHOOK_URL=https://your-approver-service.com/approve
